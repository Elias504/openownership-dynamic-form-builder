# =============================================================================
# E2E test stack environment — copy this file to .env.e2e and adjust as needed.
# Used by: docker compose --env-file .env.e2e -f compose.yaml -f compose.e2e.yml up
#
# This stack runs against a dedicated test database (formbuilder_test) with
# ddl-auto: create-drop so the schema is wiped clean on every restart.
# It uses a separate postgres volume so the main app database is never touched.
# =============================================================================

# --- PostgreSQL -----------------------------------------------------------------
# Keep POSTGRES_DB different from the main stack to avoid touching app data.
POSTGRES_DB=formbuilder_test
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
